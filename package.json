{
	"name": "@rbxts/mathcat",
	"version": "0.0.12-rc",
	"author": "Isaac Mason <isaac@isaacmason.com>",
	"description": "a collection of math helpers for 3D graphics and simulations",
	"keywords": [
		"math",
		"vector",
		"matrix",
		"quaternion",
		"euler",
		"random",
		"noise"
	],
	"license": "MIT",
	"type": "module",
	"main": "out/init.lua",
	"types": "out/index.d.ts",
	"files": [
		"out",
		"!out/tst",
		"!**/*.tsbuildinfo",
		"!**/rbxts.*"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shrjrd/rbxts-mathcat.git"
	},
	"scripts": {
		"format": "biome format --write src/.",
		"lint": "biome lint --write src/.",
		"dev": "concurrently \"rbxtsc --type game --rojo dev.project.json -w\" \"rojo serve dev.project.json\"",
		"test": "jest-roblox",
		"prepack": "pnpm format && pnpm lint && rbxtsc && node dev/convert-to-roblox-require.mjs",
		"prebuild": "pnpm prepack",
		"build": "rojo sourcemap -o sourcemap.json && rojo build -o mathcat.rbxm"
	},
	"packageManager": "pnpm@11.8.0",
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@isentinel/jest-roblox": "^0.3.5",
		"@isentinel/roblox-ts": "^4.0.7",
		"@rbxts/biome-plugin-roblox-ts": "^0.2.1",
		"@rbxts/compiler-types": "^3.0.0-types.0",
		"@rbxts/jest": "3.16.0-ts.1",
		"@rbxts/jest-globals": "3.16.0-ts.1",
		"@rbxts/types": "^1.0.894",
		"jiti": "^2.7.0",
		"typescript": "6.0.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
